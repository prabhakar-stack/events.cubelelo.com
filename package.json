{
  "name": "cubers",
  "version": "0.1.0",
  "private": true,
  "description": "Cubelelo Events Platform — Phase 1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "npx playwright test",
    "start": "npm run start --workspace=apps/api"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "ngrok": "^5.0.0-beta.2"
  }
}
