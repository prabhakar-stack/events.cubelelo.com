# ──────────────────────────────────────────────
# Cubelelo Events Platform — environment template
# Copy to .env.local (web) / .env (api). No live keys committed.
# ──────────────────────────────────────────────

# ── Web (apps/web) ──
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── API (apps/api) ──
PORT=4000
DATABASE_URL=
REDIS_URL=

# ── Supabase (auth + DB) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWKS_URL=

# ── Razorpay ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── WCA verification ──
WCA_API_BASE=https://www.worldcubeassociation.org/api/v0

# ── Email (Resend / SES) ──
RESEND_API_KEY=

# ── Storage (Cloudflare R2, avatars) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
