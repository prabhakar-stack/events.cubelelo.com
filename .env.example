# ──────────────────────────────────────────────
# Cubelelo Events Platform — environment template
# Copy to .env.local (web) / .env (api). No live keys committed.
# ──────────────────────────────────────────────

# ── Web (apps/web) ──
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── API (apps/api) ──
PORT=4000
# PostgreSQL connection string. Leave blank to use the in-memory store (dev only).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Supabase example: postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
DATABASE_URL=
REDIS_URL=

# ── Auth ──
# Leave Supabase blank to use the local dev sign-in (HS256). Fill these to
# switch the API to verifying real Supabase RS256 tokens via JWKS.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: defaults to <SUPABASE_URL>/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=
# Secret for local dev tokens (only used when Supabase is not configured).
DEV_AUTH_SECRET=dev-secret-change-me

# ── Razorpay ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── WCA verification ──
WCA_API_BASE=https://www.worldcubeassociation.org/api/v0

# ── Email (Resend / SES) ──
RESEND_API_KEY=

# ── Storage (Cloudflare R2, avatars) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
